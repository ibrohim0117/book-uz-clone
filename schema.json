    "components": {
        "schemas": {
            "AuthorCreate": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "full_name": {
                        "type": "string",
                        "maxLength": 40
                    },
                    "about": {
                        "type": "string"
                    },
                    "add_user": {
                        "type": "integer",
                        "nullable": true
                    }
                },
                "required": [
                    "about",
                    "created_at",
                    "full_name",
                    "id",
                    "updated_at"
                ]
            },
            "Book": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "book_image": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/BookImage"
                        },
                        "readOnly": true
                    },
                    "name": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "slug": {
                        "type": "string",
                        "readOnly": true,
                        "pattern": "^[-a-zA-Z0-9_]+$"
                    },
                    "price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$"
                    },
                    "about": {
                        "type": "string"
                    },
                    "count": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "is_active": {
                        "type": "boolean"
                    },
                    "info": {},
                    "views": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "add_user": {
                        "type": "integer",
                        "readOnly": true,
                        "nullable": true
                    },
                    "category": {
                        "type": "integer",
                        "nullable": true
                    },
                    "author": {
                        "type": "integer",
                        "nullable": true
                    }
                },
                "required": [
                    "about",
                    "add_user",
                    "book_image",
                    "count",
                    "created_at",
                    "id",
                    "name",
                    "price",
                    "slug",
                    "updated_at",
                    "views"
                ]
            },
            "BookImage": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "image": {
                        "type": "string",
                        "format": "uri"
                    }
                },
                "required": [
                    "id",
                    "image"
                ]
            },
            "Category": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "maxLength": 300
                    },
                    "slug": {
                        "type": "string",
                        "readOnly": true,
                        "pattern": "^[-a-zA-Z0-9_]+$"
                    },
                    "category_image": {
                        "type": "string",
                        "format": "uri",
                        "nullable": true
                    },
                    "books": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "readOnly": true
                    }
                },
                "required": [
                    "books",
                    "id",
                    "name",
                    "slug"
                ]
            },
            "PaginatedAuthorCreateList": {
                "type": "object",
                "required": [
                    "count",
                    "results"
                ],
                "properties": {
                    "count": {
                        "type": "integer",
                        "example": 123
                    },
                    "next": {
                        "type": "string",
                        "nullable": true,
                        "format": "uri",
                        "example": "http://api.example.org/accounts/?page=4"
                    },
                    "previous": {
                        "type": "string",
                        "nullable": true,
                        "format": "uri",
                        "example": "http://api.example.org/accounts/?page=2"
                    },
                    "results": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AuthorCreate"
                        }
                    }
                }
            },
            "PaginatedBookList": {
                "type": "object",
